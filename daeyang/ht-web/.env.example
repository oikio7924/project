# 홈택스빌 세금계산서 연동
HOMETAX_INVOICE_PROVIDER=hometaxbill
HOMETAXBILL_ID=
HOMETAXBILL_PASS=
HOMETAXBILL_APIKEY=

# 홈택스빌 서버 (테스트: http://115.68.1.5 / 운영: https://www.hometaxbill.com)
HOMETAXBILL_HOST=115.68.1.5
HOMETAXBILL_PROTOCOL=http

# MariaDB
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=
MARIADB_DATABASE=htweb

# DB 초기화 (true: 전체 DROP 후 재생성 / false: 신규 테이블·컬럼만 추가)
DB_RESET=false

# 서버
PORT=3000
SITE_DOMAIN=http://localhost:3000
BASE_PATH=/htweb
SESSION_SECRET=
